<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ECFSEC</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://unpkg.com/lucide@latest"></script>
<style>
@keyframes blob {
  0% { transform: translate(0px, 0px) scale(1); }
  33% { transform: translate(30px, -50px) scale(1.1); }
  66% { transform: translate(-20px, 20px) scale(0.9); }
  100% { transform: translate(0px, 0px) scale(1); }
}
.animate-blob {
  animation: blob 15s infinite alternate ease-in-out;
}
.nav-transition {
  transition: clip-path 0.7s cubic-bezier(0.86, 0, 0.07, 1);
}
.clip-circle-closed {
  clip-path: circle(0px at calc(100% - 3rem) 3rem);
}
.clip-circle-open {
  clip-path: circle(250% at calc(100% - 3rem) 3rem);
}
.glass-panel {
  background: rgba(5, 5, 5, 0.5);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(39, 39, 42, 0.4);
}
</style>
</head>
<body class="bg-[#050505] text-zinc-300 font-sans selection:bg-white selection:text-black">
<div class="min-h-screen relative overflow-hidden flex flex-col">
  <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="absolute top-[10%] left-[20%] w-[40rem] h-[40rem] bg-zinc-800/20 rounded-full mix-blend-screen filter blur-[120px] animate-blob"></div>
    <div class="absolute bottom-[10%] right-[10%] w-[45rem] h-[45rem] bg-zinc-900/40 rounded-full mix-blend-screen filter blur-[150px] animate-blob" style="animation-delay: -5s;"></div>
  </div>

  <nav id="navbar" class="fixed w-full z-50 transition-all duration-300 py-6">
    <div id="nav-bg" class="absolute inset-0 glass-panel border-b-0 border-t-0 border-l-0 border-r-0 transition-opacity duration-300" style="opacity: 0;"></div>
    <div class="max-w-7xl mx-auto px-6 flex justify-between items-center relative z-10">
      <button onclick="navigate('home')" class="flex items-center gap-3 group">
        <i data-lucide="shield" class="w-7 h-7 text-white group-hover:scale-110 transition-transform"></i>
        <span class="text-white font-bold tracking-widest text-xl">ECFSEC</span>
      </button>
      
      <div class="hidden md:flex gap-8 items-center glass-panel px-8 py-3 rounded-full" id="desktop-nav">
      </div>

      <button class="md:hidden text-white z-50 p-2 glass-panel rounded-full" onclick="toggleMobileMenu()">
        <i data-lucide="menu" class="w-6 h-6" id="menu-icon"></i>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="fixed inset-0 z-40 md:hidden bg-[#050505]/90 backdrop-blur-2xl nav-transition clip-circle-closed flex items-center justify-center">
    <div class="flex flex-col gap-10 items-center" id="mobile-nav">
    </div>
  </div>

  <main id="main-content" class="flex-grow z-10"></main>

  <footer class="py-8 px-6 border-t border-zinc-900/50 glass-panel z-10 text-center relative mt-auto">
    <p class="text-zinc-500 text-sm tracking-widest font-medium uppercase">
      &copy; <span id="year"></span> ECFSEC. All rights reserved. Location: Undisclosed.
    </p>
  </footer>
</div>

<script>
  let currentView = 'home';
  let isMobileMenuOpen = false;
  let projects = [];
  let blogs = [];
  const navItems = ['home', 'about', 'projects', 'blogs', 'contact'];

  document.getElementById('year').textContent = new Date().getFullYear();

  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 50;
    const navbar = document.getElementById('navbar');
    const navBg = document.getElementById('nav-bg');
    if (scrolled) {
      navbar.classList.remove('py-6');
      navbar.classList.add('py-4');
      navBg.style.opacity = '1';
    } else {
      navbar.classList.remove('py-4');
      navbar.classList.add('py-6');
      navBg.style.opacity = '0';
    }
  });

  function renderNav() {
    const createLinks = () => navItems.map(item => `
      <button onclick="navigate('${item}')" class="uppercase tracking-widest text-sm font-medium transition-colors hover:text-white ${currentView === item ? 'text-white' : 'text-zinc-500'}">
        ${item}
      </button>
    `).join('');
    document.getElementById('desktop-nav').innerHTML = createLinks();
    document.getElementById('mobile-nav').innerHTML = createLinks();
  }

  function toggleMobileMenu() {
    isMobileMenuOpen = !isMobileMenuOpen;
    const menu = document.getElementById('mobile-menu');
    const icon = document.getElementById('menu-icon');
    if (isMobileMenuOpen) {
      menu.classList.remove('clip-circle-closed');
      menu.classList.add('clip-circle-open');
      icon.setAttribute('data-lucide', 'x');
    } else {
      menu.classList.remove('clip-circle-open');
      menu.classList.add('clip-circle-closed');
      icon.setAttribute('data-lucide', 'menu');
    }
    lucide.createIcons();
  }

  function navigate(view) {
    currentView = view;
    if (isMobileMenuOpen) {
      toggleMobileMenu();
    }
    window.scrollTo(0, 0);
    renderNav();
    renderView();
  }

  const views = {
    home: () => `
      <div class="opacity-0 transition-opacity duration-700" id="view-container">
        <section class="relative pt-40 pb-32 px-6 flex flex-col justify-center min-h-[90vh] z-10">
          <div class="max-w-7xl mx-auto w-full">
            <div class="inline-block border border-zinc-800 glass-panel px-4 py-2 rounded-full text-xs font-semibold tracking-widest mb-8 text-zinc-300">
              ELITE CODE FORTIFICATION SECURITY
            </div>
            <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold text-white tracking-tighter leading-[1.1] mb-8 max-w-4xl drop-shadow-2xl">
              We architect absolute silence in the face of catastrophic threats.
            </h1>
            <p class="text-lg md:text-xl text-zinc-400 max-w-2xl leading-relaxed font-light mb-12">
              ECFSEC is a private, high‑integrity organization for security‑focused software engineers. We do not mitigate risk; we eradicate vulnerabilities with merciless precision before malicious actors can draw breath.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <button onclick="navigate('contact')" class="bg-white text-black px-8 py-4 rounded-full font-semibold tracking-wide hover:bg-zinc-200 transition-colors flex items-center justify-center gap-2 shadow-[0_0_30px_rgba(255,255,255,0.1)]">
                INITIATE CONTACT <i data-lucide="chevron-right" class="w-4 h-4"></i>
              </button>
              <button onclick="navigate('about')" class="glass-panel text-white px-8 py-4 rounded-full font-semibold tracking-wide hover:bg-zinc-900/80 transition-colors">
                VIEW CLASSIFIED DOCTRINE
              </button>
            </div>
          </div>
        </section>

        <section class="py-32 px-6 z-10 relative">
          <div class="max-w-7xl mx-auto">
            <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight mb-4">Tactical Operations</h2>
            <p class="text-zinc-400 mb-16 max-w-2xl text-lg">Our engineering protocols are ruthless. We deploy unrelenting defensive mechanisms designed to crush adversarial incursions upon impact.</p>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div class="p-8 rounded-3xl glass-panel hover:border-zinc-500/50 transition-colors group">
                <i data-lucide="crosshair" class="w-10 h-10 text-white mb-6 group-hover:scale-110 transition-transform" stroke-width="1.5"></i>
                <h3 class="text-xl font-bold text-white mb-3 tracking-wide">Adversarial Annihilation</h3>
                <p class="text-zinc-400 leading-relaxed text-sm">
                  Surgical simulation of hostile state-actor breaches. We systematically dismantle your architecture to identify fatal flaws, weaponizing our findings to forge impenetrable infrastructure.
                </p>
              </div>
              <div class="p-8 rounded-3xl glass-panel hover:border-zinc-500/50 transition-colors group">
                <i data-lucide="server" class="w-10 h-10 text-white mb-6 group-hover:scale-110 transition-transform" stroke-width="1.5"></i>
                <h3 class="text-xl font-bold text-white mb-3 tracking-wide">Cryptographic Quarantine</h3>
                <p class="text-zinc-400 leading-relaxed text-sm">
                  Lethal containment strategies for volatile digital contagions. We isolate and dissect zero-day payloads in the abyss, neutralizing them before they can initiate catastrophic propagation.
                </p>
              </div>
              <div class="p-8 rounded-3xl glass-panel hover:border-zinc-500/50 transition-colors group">
                <i data-lucide="eye-off" class="w-10 h-10 text-white mb-6 group-hover:scale-110 transition-transform" stroke-width="1.5"></i>
                <h3 class="text-xl font-bold text-white mb-3 tracking-wide">Perimeter Obliteration</h3>
                <p class="text-zinc-400 leading-relaxed text-sm">
                  Advanced offensive security maneuvers masking as defense. We engineer shadow perimeters that actively retaliate against unauthorized telemetry and hostile reconnaissance sweeps.
                </p>
              </div>
            </div>
          </div>
        </section>
      </div>
    `,
    about: () => `
      <section class="py-40 px-6 min-h-screen z-10 relative flex items-center opacity-0 transition-opacity duration-700" id="view-container">
        <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center">
          <div class="w-full lg:w-1/2">
            <div class="grid grid-cols-2 gap-4">
              <div class="aspect-square glass-panel rounded-3xl flex items-center justify-center p-8">
                <i data-lucide="lock" class="w-full h-full text-zinc-600/50" stroke-width="0.5"></i>
              </div>
              <div class="aspect-square glass-panel rounded-3xl flex items-center justify-center relative overflow-hidden">
                <i data-lucide="activity" class="w-32 h-32 text-zinc-700/30 absolute -right-8 -bottom-8"></i>
              </div>
              <div class="aspect-square glass-panel rounded-3xl flex items-center justify-center relative overflow-hidden">
                <i data-lucide="cpu" class="w-32 h-32 text-zinc-700/30 absolute -left-8 -top-8"></i>
              </div>
              <div class="aspect-square glass-panel rounded-3xl flex items-center justify-center p-8">
                <i data-lucide="shield" class="w-full h-full text-zinc-600/50" stroke-width="0.5"></i>
              </div>
            </div>
          </div>
          <div class="w-full lg:w-1/2">
            <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight mb-6">The Architecture of Fear</h2>
            <p class="text-zinc-300 text-lg leading-relaxed mb-6">
              Security is not a checkbox; it is the manifestation of paranoia engineered into immutable code. At ECFSEC, we operate in the shadows of the stack, identifying the microscopic fractures that lead to global systemic collapse.
            </p>
            <p class="text-zinc-300 text-lg leading-relaxed mb-8">
              We do not hire developers. We recruit architects of the abyss—individuals capable of staring into the void of compiled logic and anticipating the predatory instincts of the world's most dangerous adversaries.
            </p>
            <div class="space-y-4">
              <div class="flex items-center gap-4 text-white glass-panel p-4 rounded-full">
                <div class="w-3 h-3 bg-white rounded-full"></div>
                <span class="font-medium tracking-wide">Zero Tolerance Configuration</span>
              </div>
              <div class="flex items-center gap-4 text-white glass-panel p-4 rounded-full">
                <div class="w-3 h-3 bg-white rounded-full"></div>
                <span class="font-medium tracking-wide">Hostile Environment Deployment</span>
              </div>
              <div class="flex items-center gap-4 text-white glass-panel p-4 rounded-full">
                <div class="w-3 h-3 bg-white rounded-full"></div>
                <span class="font-medium tracking-wide">Immutable Execution Layers</span>
              </div>
            </div>
          </div>
        </div>
      </section>
    `,
    projects: () => `
      <section class="py-40 px-6 min-h-screen z-10 relative opacity-0 transition-opacity duration-700" id="view-container">
        <div class="max-w-7xl mx-auto">
          <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight mb-4">Active Fortifications</h2>
          <p class="text-zinc-400 mb-16 max-w-2xl text-lg">Classified architectural overhauls and grid neutralizations executed by our operatives.</p>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            ${projects.map(proj => `
              <div class="p-8 rounded-3xl glass-panel flex flex-col justify-between">
                <div>
                  <div class="inline-block px-3 py-1 bg-white/10 text-white text-xs font-bold rounded-full mb-6 tracking-widest uppercase">
                    ${proj.status}
                  </div>
                  <h3 class="text-2xl font-bold text-white mb-4">${proj.name}</h3>
                  <p class="text-zinc-400 leading-relaxed text-sm mb-8">${proj.description}</p>
                </div>
                <button onclick="window.location.href='${proj.url}'" class="text-white font-semibold flex items-center gap-2 hover:gap-4 transition-all text-sm tracking-widest">
                  ACCESS RECORDS <i data-lucide="arrow-right" class="w-4 h-4"></i>
                </button>
              </div>
            `).join('')}
          </div>
        </div>
      </section>
    `,
    blogs: () => `
      <section class="py-40 px-6 min-h-screen z-10 relative opacity-0 transition-opacity duration-700" id="view-container">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight mb-4">Operational Intelligence</h2>
          <p class="text-zinc-400 mb-16 text-lg">Declassified findings, threat modeling theories, and architectural mandates.</p>
          <div class="space-y-6">
            ${blogs.map(blog => `
              <div class="p-8 rounded-3xl glass-panel hover:bg-zinc-900/40 transition-colors cursor-pointer group">
                <div class="text-zinc-500 text-xs font-bold tracking-widest mb-3">${blog.date}</div>
                <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-zinc-300 transition-colors">${blog.title}</h3>
                <p class="text-zinc-400 leading-relaxed">${blog.excerpt}</p>
              </div>
            `).join('')}
          </div>
        </div>
      </section>
    `,
    contact: () => `
      <section class="py-40 px-6 min-h-screen z-10 relative flex items-center justify-center opacity-0 transition-opacity duration-700" id="view-container">
        <div class="max-w-2xl w-full text-center glass-panel p-10 md:p-16 rounded-[3rem]">
          <i data-lucide="lock" class="w-12 h-12 text-zinc-500 mx-auto mb-8"></i>
          <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight mb-6">Access is strictly regulated.</h2>
          <p class="text-zinc-400 text-lg leading-relaxed mb-10 mx-auto">
            ECFSEC operates beyond public scrutiny. Submitting your credentials does not guarantee acknowledgment.
          </p>
          <form class="space-y-6 text-left">
            <div>
              <label class="block text-xs font-bold tracking-widest text-zinc-400 mb-2 uppercase ml-2">Entity Designation</label>
              <input type="text" class="w-full bg-zinc-900/50 border border-zinc-700/50 focus:border-white text-white px-6 py-4 rounded-full outline-none transition-colors backdrop-blur-sm" />
            </div>
            <div>
              <label class="block text-xs font-bold tracking-widest text-zinc-400 mb-2 uppercase ml-2">Secure Comm Link</label>
              <input type="email" class="w-full bg-zinc-900/50 border border-zinc-700/50 focus:border-white text-white px-6 py-4 rounded-full outline-none transition-colors backdrop-blur-sm" />
            </div>
            <div>
              <label class="block text-xs font-bold tracking-widest text-zinc-400 mb-2 uppercase ml-2">Nature of Threat</label>
              <textarea rows="4" class="w-full bg-zinc-900/50 border border-zinc-700/50 focus:border-white text-white px-6 py-4 rounded-3xl outline-none transition-colors backdrop-blur-sm resize-none"></textarea>
            </div>
            <button type="button" class="w-full bg-white text-black font-bold tracking-widest py-4 rounded-full hover:bg-zinc-200 transition-colors mt-4 shadow-[0_0_20px_rgba(255,255,255,0.1)]">
              SUBMIT FOR VERIFICATION
            </button>
          </form>
        </div>
      </section>
    `
  };

  function renderView() {
    const mainContent = document.getElementById('main-content');
    mainContent.innerHTML = views[currentView]();
    lucide.createIcons();
    setTimeout(() => {
      const container = document.getElementById('view-container');
      if (container) {
        container.classList.remove('opacity-0');
        container.classList.add('opacity-100');
      }
    }, 50);
  }

  Promise.all([
    fetch('projects.json').then(res => res.json()).catch(() => []),
    fetch('blogs.json').then(res => res.json()).catch(() => [])
  ]).then(([projectsData, blogsData]) => {
    projects = projectsData || [];
    blogs = blogsData || [];
    renderNav();
    renderView();
  });
</script>
</body>
</html>